<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Startup Blog</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{
  background:#0f172a;
  color:#fff;
  overflow-x:hidden;
}

header{
  padding:20px 50px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  position:fixed;
  width:100%;
  background:rgba(0,0,0,0.3);
  backdrop-filter:blur(10px);
  z-index:1000;
}

header h1{
  color:#22c55e;
}

nav a{
  margin-left:20px;
  text-decoration:none;
  color:#fff;
  transition:0.3s;
}

nav a:hover{
  color:#22c55e;
}

.hero{
  height:100vh;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  background:linear-gradient(135deg,#0f172a,#020617);
}

.hero h2{
  font-size:3rem;
  margin-bottom:20px;
}

.hero p{
  opacity:0.7;
}

.btn{
  margin-top:20px;
  padding:12px 25px;
  background:#22c55e;
  border:none;
  border-radius:30px;
  color:#000;
  cursor:pointer;
  transition:0.3s;
}

.btn:hover{
  transform:scale(1.1);
}

.blogs{
  padding:100px 50px;
}

.blog-container{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
}

.card{
  background:#1e293b;
  padding:20px;
  border-radius:15px;
  transition:0.3s;
}

.card:hover{
  transform:translateY(-10px);
}

.card h3{
  margin-bottom:10px;
}

footer{
  text-align:center;
  padding:20px;
  background:#020617;
}

.popup{
  position:fixed;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%) scale(0);
  background:#1e293b;
  padding:30px;
  border-radius:15px;
  transition:0.3s;
}

.popup.active{
  transform:translate(-50%,-50%) scale(1);
}

</style>
</head>

<body>

<header>
  <h1>MyStartup</h1>
  <nav>
    <a href="#">Home</a>
    <a href="#blogs">Blogs</a>
    <a href="#">About</a>
  </nav>
</header>

<section class="hero">
  <h2>Building the Future 🚀</h2>
  <p>Follow my startup journey, ideas, failures & success</p>
  <button class="btn" onclick="openPopup()">Subscribe</button>
</section>

<section class="blogs" id="blogs">
  <h2>Latest Blogs</h2>
  <div class="blog-container" id="blogContainer"></div>
</section>

<div class="popup" id="popup">
  <h3>Subscribe to updates</h3>
  <input type="email" placeholder="Enter email" style="padding:10px;width:100%;margin:10px 0;border-radius:10px;border:none;">
  <button class="btn" onclick="closePopup()">Close</button>
</div>

<footer>
  <p>© 2026 MyStartup | Built with ❤️</p>
</footer>

<script>

const blogs = [
  {title:"My Startup Idea", content:"How I came up with my startup idea..."},
  {title:"Challenges Faced", content:"Struggles during initial phase..."},
  {title:"First Client", content:"Landing my first customer..."},
  {title:"Scaling Up", content:"Growing the business step by step..."}
];

const container = document.getElementById("blogContainer");

function loadBlogs(){
  blogs.forEach(blog => {
    const card = document.createElement("div");
    card.classList.add("card");
    card.innerHTML = `<h3>${blog.title}</h3><p>${blog.content}</p>`;
    container.appendChild(card);
  });
}

function openPopup(){
  document.getElementById("popup").classList.add("active");
}

function closePopup(){
  document.getElementById("popup").classList.remove("active");
}

window.onload = loadBlogs;

</script>

</body>
</html>
